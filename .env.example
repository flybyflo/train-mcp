PORT=8000
OEBB_BASE_URL=https://v6.oebb.transport.rest/api

# Optional local Postgres from docker-compose.yml.
DATABASE_URL=postgres://train_mcp:train_mcp@127.0.0.1:55432/train_mcp
DB_MAX_CONNECTIONS=10
DB_ACQUIRE_TIMEOUT_SECONDS=5
HISTORY_MAX_LIMIT=100

# Optional JWT auth. Required only for persisted per-user history.
# AUTH_JWT_HS256_SECRET=change-me
# AUTH_JWT_ISSUER=train-mcp
# AUTH_JWT_AUDIENCE=train-mcp-clients

MCP_ALLOWED_ORIGINS=
MCP_MAX_CONCURRENCY=128
MCP_RATE_LIMIT_PER_SECOND=30
MCP_QUEUE_TIMEOUT_MS=250
MCP_MAX_BODY_BYTES=131072

CODEMODE_EXECUTION_TIMEOUT_MS=30000
CODEMODE_EXECUTION_QUEUE_TIMEOUT_MS=2000
CODEMODE_MAX_PARALLEL_EXECUTIONS=8
CODEMODE_MEMORY_LIMIT_BYTES=33554432
CODEMODE_MAX_STACK_BYTES=524288
CODEMODE_GC_THRESHOLD_BYTES=8388608
